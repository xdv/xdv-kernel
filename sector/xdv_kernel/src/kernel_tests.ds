forge KernelTests {

    const TEST_PASS: UInt32 = 0;
    const TEST_FAIL: UInt32 = 1;

    proc K::test_boot_contract_assertion() -> UInt32 {
        let status = kernel_assert_boot_contract();
        if status == TEST_PASS {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::test_split_dependency_interface_assertion() -> UInt32 {
        let status = kernel_assert_split_dependency_interfaces();
        if status == TEST_PASS {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::test_runtime_contract_assertion() -> UInt32 {
        let status = kernel_assert_runtime_contract();
        if status == TEST_PASS {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::test_kernel_init_boot() -> UInt32 {
        let status = init_kernel_boot();
        if status == TEST_PASS {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::test_runtime_load_boot() -> UInt32 {
        let status = load_runtime_boot();
        if status == TEST_PASS {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::test_runtime_start_boot() -> UInt32 {
        let status = start_runtime_boot();
        if status == TEST_PASS {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::test_uptime() -> UInt32 {
        let uptime = get_uptime();
        if uptime > 0 {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::test_memory_usage() -> UInt32 {
        let usage = get_memory_usage();
        if usage > 0 {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::test_process_count() -> UInt32 {
        let count = get_process_count();
        if count > 0 {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }
}